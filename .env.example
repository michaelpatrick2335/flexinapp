# Copy this file to .env and fill in real values. NEVER commit .env to git.

# Stripe (use TEST keys for development, LIVE keys only in Vercel env vars)
STRIPE_SECRET_KEY=sk_test_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Vercel Postgres (set in Vercel dashboard, auto-injected at deploy)
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=

# Vercel Blob storage (for body scan photos)
# BLOB_READ_WRITE_TOKEN=

# RevenueCat (iOS in-app purchase) — set in Codemagic env vars
# VITE_REVENUECAT_IOS_KEY=appl_xxx

# Session secret (random string, set in Vercel)
# SESSION_SECRET=
